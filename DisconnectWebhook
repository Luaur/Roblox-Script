-- FILE SYSTEM (AUTO-SAVE/LOAD)
local FileName = "Spectre_Config_v2.json"
function Spectre:LoadConfig()
    if isfile and isfile(FileName) then
        local success, decoded = pcall(function() return Spectre.Services.Http:JSONDecode(readfile(FileName)) end)
        if success and decoded then
            self.Config.Webhook = decoded.Webhook or ""
            self.Config.DiscordID = decoded.DiscordID or ""
            self.Config.Enabled = decoded.Enabled
            if self.Config.Enabled == nil then self.Config.Enabled = true end
        end
    end
end

function Spectre:SaveConfig()
    if writefile then
        local data = {
            Webhook = self.Config.Webhook,
            DiscordID = self.Config.DiscordID,
            Enabled = self.Config.Enabled
        }
        writefile(FileName, self.Services.Http:JSONEncode(data))
    end
end

-- HELPER FUNCTIONS
local floor = math.floor
local format = string.format
local insert = table.insert
local remove = table.remove

local function GetDevice()
    return Spectre.Services.Input.TouchEnabled and "Mobile" or "PC"
end

local function FormatTime(s)
    return format("%02d:%02d:%02d", floor(s/3600), floor((s%3600)/60), s%60)
end

local function HttpRequest(url, body)
    if url == "" or not url:find("http") then return end -- Jangan kirim jika webhook kosong
    local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if req then
        req({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = Spectre.Services.Http:JSONEncode(body)
        })
    end
end

function Spectre:CaptureBlackbox()
    local ping = floor(self.Services.Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    local fps = floor(workspace:GetRealPhysicsFPS())
    local ram = floor(self.Services.Stats:GetTotalMemoryUsageMb())
    local timeStr = os.date("%X")
    
    insert(self.State.PingHistory, {p=ping, f=fps, r=ram, t=timeStr})
    if #self.State.PingHistory > 10 then remove(self.State.PingHistory, 1) end
    return ping, ram, fps
end

function Spectre:FormatBlackboxLog()
    local log = "```ini\n[TIME]    [PING]  [FPS]  [RAM]\n"
    for _, data in ipairs(self.State.PingHistory) do
        log = log .. format("%s  %3dms   %2d    %4dMB\n", data.t, data.p, data.f, data.r)
    end
    return log .. "```"
end

function Spectre:Dispatch(category, reason, color, priority)
    -- Cek Toggle
    if not self.Config.Enabled and not priority then return end 
    if self.State.Disconnected and not priority then return end
    if not priority then self.State.Disconnected = true end

    if self.UI and not priority then 
        self.UI.Main.Status.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        self.UI.Main.Title.Text = "DISCONNECTED" 
    end

    local pingContent = (self.Config.PingUser and not priority and self.Config.DiscordID ~= "") and ("<@"..self.Config.DiscordID..">") or ""
    local blackbox = self:FormatBlackboxLog()
    
    local fields = {
        {["name"] = "Device", ["value"] = GetDevice(), ["inline"] = true},
        {["name"] = "Uptime", ["value"] = FormatTime(os.time() - self.StartTime), ["inline"] = true},
        {["name"] = "Reason", ["value"] = reason, ["inline"] = false}
    }

    if not priority then
        insert(fields, {["name"] = "Spectre Blackbox", ["value"] = blackbox, ["inline"] = false})
    end

    local payload = {
        ["content"] = pingContent,
        ["embeds"] = {{
            ["title"] = category,
            ["color"] = color,
            ["fields"] = fields,
            ["footer"] = {["text"] = "Spectre: Zero Point"},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    task.spawn(function() pcall(function() HttpRequest(self.Config.Webhook, payload) end) end)
    
    if not priority then
        local t = os.clock()
        while os.clock() - t < 1.5 do end
    end
end

