    -- Draggable
    local dragging, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function Spectre:StartListeners()
    self.StartTime = os.time()
    
    self.Services.Gui.ErrorMessageChanged:Connect(function()
        local err = self.Services.Gui:GetErrorMessage()
        if err and err ~= "" and not self.State.Teleporting then
            self:Dispatch("🚨 SIGNAL LOST", err, 16711680, false)
        end
    end)
    
    self.Services.Input.WindowFocusReleased:Connect(function()
        if not self.State.Disconnected then
            self.State.Background = true
            self:Dispatch("📱 BACKGROUND MODE", "Application minimized.", 16753920, true)
            if self.UI then self.UI.Main.Status.BackgroundColor3 = Color3.fromRGB(255, 165, 0) end
        end
    end)
    
    self.Services.Input.WindowFocused:Connect(function()
        if self.State.Background then
            self.State.Background = false
            if self.UI and self.Config.Enabled then self.UI.Main.Status.BackgroundColor3 = Color3.fromRGB(0, 255, 200) end
        end
    end)
    
    game.OnClose = function()
        if not self.State.Teleporting and not self.State.Disconnected then
            local reason = self.State.Background and "Force Close (Background)" or "Manual Kill / Crash"
            if self.Services.Stats:GetTotalMemoryUsageMb() > self.Config.CrashRAM then reason = "💥 CRASH (Memory Overflow)" end
            self:Dispatch("🚪 PROCESS TERMINATED", reason, 12370112, false)
        end
    end
    
    self.Services.Players.LocalPlayer.OnTeleport:Connect(function()
        self.State.Teleporting = true
        if self.UI then self.UI.Main.Title.Text = "TELEPORTING..." end
    end)
    
    task.spawn(function()
        while true do
            task.wait(1)
            
            if not self.State.Disconnected and not self.State.Teleporting then
                local p, r, f = self:CaptureBlackbox()
                
                if self.UI then 
                    self.UI.Main.Title.Text = format("%dms | %d MB", p, r)
                end
                
                if p == self.State.LastPing and p > 0 then
                    self.State.FreezeCount = self.State.FreezeCount + 1
                    if self.State.FreezeCount >= self.Config.PingFreezeLimit then
                        self:Dispatch("💀 GHOST DISCONNECT", "Connection Flatline Detected.", 16711680, false)
                    end
                else
                    self.State.FreezeCount = 0
                    self.State.LastPing = p
                end
            end
        end
    end)
end

